# ────────────────────────────────────────────────────────────────
# Nova — environment configuration (copy to .env and fill in)
# ────────────────────────────────────────────────────────────────

# --- App ---
NOVA_ENV=development
NOVA_DEBUG=true
NOVA_API_HOST=0.0.0.0
NOVA_API_PORT=8000
# Comma-separated list of allowed CORS origins
NOVA_CORS_ORIGINS=http://localhost:3000

# --- Security / JWT ---
# CHANGE THIS in production (openssl rand -hex 32)
NOVA_JWT_SECRET=dev-insecure-change-me
NOVA_JWT_ALGORITHM=HS256
NOVA_ACCESS_TOKEN_EXPIRE_MINUTES=30
NOVA_REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Postgres ---
NOVA_POSTGRES_HOST=localhost
NOVA_POSTGRES_PORT=5432
NOVA_POSTGRES_USER=nova
NOVA_POSTGRES_PASSWORD=nova
NOVA_POSTGRES_DB=nova
# If set, overrides the individual POSTGRES_* fields above.
# For local dev without Postgres, use SQLite:  sqlite+aiosqlite:///./nova.db
NOVA_DATABASE_URL=

# --- Redis ---
NOVA_REDIS_URL=redis://localhost:6379/0

# --- Qdrant (RAG vectors, Phase 2) ---
NOVA_QDRANT_URL=http://localhost:6333
NOVA_QDRANT_API_KEY=

# --- Providers (all optional; "mock" providers are used when unset) ---
# llm provider: mock | openai | gemini | anthropic
NOVA_LLM_PROVIDER=mock
NOVA_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# stt provider: mock | openai | deepgram
NOVA_STT_PROVIDER=mock
# tts provider: mock | openai | elevenlabs
NOVA_TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# --- OAuth (social login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NOVA_OAUTH_REDIRECT_BASE=http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
